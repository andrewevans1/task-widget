{
  "productName": "Task Widget",
  "version": "0.1.0",
  "identifier": "com.taskwidget",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Task Widget",
        "width": 380,
        "height": 560,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
